{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*", "/fonts/*", "/i18n/*", "/*.{css,js,png,svg,ico,woff2}"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
